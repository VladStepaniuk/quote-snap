// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model QuoteRule {
  id               String   @id @default(cuid())
  shop             String
  name             String
  scope            String
  scopeValue       String   @default("")
  visibility       String
  customerTag      String   @default("")
  hidePrice        Boolean  @default(true)
  replaceAddToCart Boolean  @default(true)
  quoteButtonLabel String   @default("Request a Quote")
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  // Per-rule Pro customization (null = use store default)
  buttonBgColor     String?
  buttonTextColor   String?
  buttonBorderRadius String?
  formTitle         String?
  formSuccessMsg    String?
  formShowCompany   Boolean?
  formSubmitLabel   String?
  fontFamily        String?
  fontSize          String?

  @@index([shop])
}

model GdprRequest {
  id            String   @id @default(cuid())
  shop          String
  type          String   // DATA_REQUEST | CUSTOMER_REDACT | SHOP_REDACT
  customerId    String   @default("")
  customerEmail String   @default("")
  payload       String   @default("")
  createdAt     DateTime @default(now())

  @@index([shop])
}

model ShopSettings {
  id                String   @id @default(cuid())
  shop              String   @unique
  notificationEmail String   @default("")
  emailEnabled      Boolean  @default(true)
  // Pro customization
  buttonLabel       String   @default("Request a Quote")
  buttonBgColor     String   @default("#008060")
  buttonTextColor   String   @default("#ffffff")
  buttonBorderRadius String  @default("4")
  formTitle         String   @default("Request a Quote")
  formSuccessMsg    String   @default("Thank you! We'll be in touch soon.")
  formShowCompany   Boolean  @default(true)
  formSubmitLabel   String   @default("Submit Request")
  // Font customization
  fontFamily        String   @default("inherit")
  fontSize          String   @default("16")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model QuoteRequest {
  id            String   @id @default(cuid())
  shop          String
  customerName  String
  customerEmail String
  productId     String
  company       String   @default("")
  message       String   @default("")
  status        String   @default("new")
  notes         String   @default("")
  createdAt     DateTime @default(now())

  @@index([shop])
}
